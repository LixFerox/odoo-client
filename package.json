{
	"name": "odoo-client",
	"version": "1.0.0",
	"author": "LixFerox",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/LixFerox/odoo-client.git"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/xmlrpc": "^1.3.10",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs",
			"default": "./dist/index.js"
		}
	},
	"bugs": {
		"url": "https://github.com/LixFerox/odoo-client/issues"
	},
	"description": "A client library for building integrations with the Odoo API.",
	"engines": {
		"bun": ">=1.0.0"
	},
	"files": [
		"dist",
		"README.md",
		"EXAMPLES.md",
		"LICENSE"
	],
	"homepage": "https://github.com/LixFerox/odoo-client#readme",
	"keywords": [
		"odoo",
		"client",
		"library",
		"integration",
		"api"
	],
	"license": "MIT",
	"scripts": {
		"build": "tsup src/index.ts --format esm,cjs --dts --clean",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"prepublishOnly": "bun run build && bun run typecheck"
	},
	"sideEffects": false,
	"type": "module",
	"types": "./dist/index.d.ts",
	"dependencies": {
		"xmlrpc": "^1.3.2"
	}
}
